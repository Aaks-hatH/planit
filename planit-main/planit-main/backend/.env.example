# PlanIt backend — environment variables
# Copy to .env and fill in real values. Nothing here is a secret.

# ── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
MONGODB_URI=
JWT_SECRET=

# ── URLs / mesh topology ─────────────────────────────────────────────────
# BASE_DOMAIN     — root domain events are served under (e.g. planitapp.live)
# FRONTEND_URL    — public URL of the frontend deployment
# PLANIT_FRONTEND_URL — used in place of FRONTEND_URL in some outbound links
# SELF_URL        — this backend instance's own public URL (mesh announce)
# ROUTER_URL      — the router service's URL
# WATCHDOG_URL    — the watchdog service's URL
# CORS_ORIGIN     — comma-separated list of allowed origins
BASE_DOMAIN=
FRONTEND_URL=
PLANIT_FRONTEND_URL=
SELF_URL=
ROUTER_URL=
WATCHDOG_URL=
CORS_ORIGIN=

# ── Multi-backend mesh identity ──────────────────────────────────────────
BACKEND_LABEL=
BACKEND_REGION=
IS_EDGE_SERVICE=
MESH_SECRET=

# ── Admin / demo accounts ────────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
DEMO_USERNAME=
DEMO_PASSWORD=

# ── White-label licensing ────────────────────────────────────────────────
WL_LICENSE_SECRET=
PLANIT_LICENSE_KEY=
PLANIT_INTEGRITY_PROOF_1=
PLANIT_INTEGRITY_PROOF_2=
PLANIT_INTEGRITY_PROOF_3=

# ── MCP ───────────────────────────────────────────────────────────────────
MCP_JWT_SECRET=
MCP_SERVER_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ── Cloudinary (image uploads) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Redis / Upstash (rate limiting, caching) ─────────────────────────────
REDIS_URL=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Email / lookups ───────────────────────────────────────────────────────
HUNTER_API_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
EMAIL_REMINDER_HOURS=

# ── Notifications ─────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
NTFY_URL=

# ── Security / anti-abuse ────────────────────────────────────────────────
SECURITY_ENABLED=
SECURITY_MONITOR_PATHS=
SECURITY_BAN_THRESHOLD=
SECURITY_BAN_MINUTES=
SECURITY_WARN_THRESHOLD=
SECURITY_WARN_WINDOW_S=
SECURITY_WHITELIST_IPS=
ABUSEIPDB_ENABLED=
ABUSEIPDB_API_KEY=
ABUSEIPDB_BLOCK_SCORE=
ABUSEIPDB_CACHE_TTL_S=
TARPIT_ENABLED=
TARPIT_MAX_DELAY_S=
TURNSTILE_ENABLED=
HEALTH_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_MAX=
RATE_LIMIT_WINDOW=

# ── Audit log (separate DB) ───────────────────────────────────────────────
AUDIT_MONGODB_URI=
AUDIT_ENCRYPTION_KEY=
AUDIT_RETENTION_DAYS=
ANALYTICS_RETENTION_DAYS=

# ── Misc ──────────────────────────────────────────────────────────────────
MARKETING_SCHEDULER=

# NOTE: MONGO_URI (legacy fallback in routes/admin.js) was removed in favor
# of MONGODB_URI everywhere — see step 5 of the WL hardening pass. Do not
# reintroduce it.
