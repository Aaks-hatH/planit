# PlanIt frontend — environment variables (Vite)
# Copy to .env and fill in real values. Only variables prefixed VITE_ are
# exposed to client-side code — never put secrets here.

# API / service URLs
VITE_API_URL=
VITE_ROUTER_URL=
VITE_WATCHDOG_URL=
VITE_WS_URL=

# Domain config
VITE_BASE_DOMAIN=
VITE_MAIN_DOMAIN=

# Cloudflare Turnstile (CAPTCHA)
VITE_TURNSTILE_SITE_KEY=

# WebRTC / TURN server (video calling)
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
